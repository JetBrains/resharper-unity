<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="com.intellij.platform.images"/>
    <module name="intellij.json.backend"/>
    <module name="intellij.platform.vcs.impl"/>
    <module name="intellij.rd.client"/>
    <module name="intellij.rider"/>
    <module name="intellij.rider.languages"/>
    <module name="intellij.rider.plugins.unity.backend"/>
    <module name="intellij.rider.plugins.unity.model"/>
    <module name="intellij.rider.rdclient.dotnet"/>
    <module name="intellij.rider.shared"/>
    <module name="intellij.spellchecker"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <fileType name="UnityYaml" fieldName="INSTANCE" implementationClass="com.jetbrains.rider.plugins.unity.yaml.fileTypes.UnityYamlFileType" language="UnityYaml" extensions="meta;unity;scene;prefab;asset;controller;anim"/>
    <lang.syntaxHighlighterFactory language="UnityYaml" implementationClass="org.jetbrains.yaml.YAMLSyntaxHighlighterFactory"/>
    <iconProvider implementation="com.jetbrains.rider.plugins.unity.yaml.fileTypes.UnityYamlIconProvider" />
    <diff.merge.external.AutomaticExternalMergeTool implementation="com.jetbrains.rider.plugins.unity.diff.UnityYamlAutomaticExternalMergeTool"/>
    <rider.gotoCustomizer implementation="com.jetbrains.rider.plugins.unity.yaml.gotoType.UnityGotoCustomizer"/>
    <navbar implementation="com.jetbrains.rider.plugins.unity.yaml.navigationToolbar.UnityNavBarModelExtension"/>
    <lang.parserDefinition language="UnityYaml" implementationClass="com.jetbrains.rider.plugins.unity.yaml.fileTypes.UnityYamlParserDefinition" />
  </extensions>
  <resource-bundle>messages.UnityYamlBundle</resource-bundle>
</idea-plugin>