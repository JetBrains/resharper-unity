    <plugin id="com.intellij.platform.images"/>
    <module name="intellij.rd.ide.model.generated"/>
    <module name="intellij.rd.platform"/>
    <module name="intellij.grid.core.impl"/>
    <module name="intellij.grid.impl"/>
    <module name="intellij.platform.debugger.impl.frontend"/>
    <module name="intellij.rider.debugger.shared"/>
    <module name="intellij.rider.plugins.unity.debugger.textureVisualizer.common"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <rider.debugger.link.provider implementation="intellij.rider.plugins.unity.debugger.textureVisualizer.frontend.UnityTextureLinkProvider"/>
    <xdebugger.nodeLinkActionProvider implementation="intellij.rider.plugins.unity.debugger.textureVisualizer.frontend.UnityTextureXDebuggerNodeLinkProvider"/>
    <statistics.counterUsagesCollector implementationClass="intellij.rider.plugins.unity.debugger.textureVisualizer.frontend.TextureDebuggerCollector"/>

  </extensions>

</idea-plugin>
